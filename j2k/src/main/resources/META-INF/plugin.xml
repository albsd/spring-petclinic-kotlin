<idea-plugin>
    <id>com.albsd.j2k</id>
    <name>J2K</name>
    <version>1.0.0</version>
    <vendor>albsd</vendor>
    <description><![CDATA[
	Java-to-Kotlin converter for CI pipelines.
	Reads Java source from j2k.sourceDir
	and writes Kotlin output to j2k.outputDir.
	]]>
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <applicationListeners>
        <listener class="com.albsd.j2k.J2kAppListener" topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

</idea-plugin>
